{
  "name": "directive-website",
  "version": "0.1.8",
  "private": true,
  "description": "Documentation site for Directive - constraint-driven state management for TypeScript",
  "scripts": {
    "dev": "next dev",
    "build": "tsx scripts/extract-api-docs.ts && tsx scripts/generate-embeddings.ts && next build",
    "build:next-only": "next build",
    "build:api-docs": "tsx scripts/extract-api-docs.ts",
    "build:embeddings": "tsx scripts/generate-embeddings.ts",
    "start": "next start",
    "lint": "next lint",
    "build:example": "tsx scripts/build-example.ts",
    "build:examples": "tsx scripts/build-example.ts --all",
    "test:e2e": "npx playwright test --config e2e/playwright.config.ts",
    "test:e2e:ui": "npx playwright test --config e2e/playwright.config.ts --ui",
    "test:e2e:headed": "npx playwright test --config e2e/playwright.config.ts --headed"
  },
  "browserslist": "defaults, not ie <= 11",
  "dependencies": {
    "@algolia/autocomplete-core": "^1.19.2",
    "@directive-run/ai": "workspace:*",
    "@directive-run/core": "workspace:*",
    "@directive-run/react": "workspace:*",
    "@headlessui/react": "^2.2.6",
    "@markdoc/markdoc": "^0.5.2",
    "@markdoc/next.js": "^0.5.0",
    "@phosphor-icons/react": "^2.1.10",
    "@sindresorhus/slugify": "^2.2.1",
    "@stackblitz/sdk": "^1.11.0",
    "@tailwindcss/postcss": "^4.1.15",
    "@tailwindcss/typography": "^0.5.16",
    "@types/react-highlight-words": "^0.20.0",
    "@xyflow/react": "^12.4.4",
    "clsx": "^2.1.1",
    "fast-glob": "^3.3.3",
    "flexsearch": "^0.8.205",
    "geist": "^1.7.0",
    "js-yaml": "^4.1.0",
    "next": "^15.5.10",
    "next-themes": "^0.4.6",
    "pako": "^2.1.0",
    "perfect-freehand": "^1.2.3",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-highlight-words": "^0.21.0",
    "simple-functional-loader": "^1.2.1",
    "tailwindcss": "^4.1.15",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^24.1.0",
    "@types/pako": "^2.0.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.32.0",
    "eslint-config-next": "^15",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "sharp": "0.34.3",
    "ts-morph": "^27.0.2",
    "tsx": "^4.21.0"
  }
}
