{
  "name": "@directive-run/ai",
  "version": "0.5.0",
  "description": "AI agent orchestration, guardrails, and multi-agent coordination for Directive.",
  "license": "MIT",
  "author": "Jason Comes",
  "repository": {
    "type": "git",
    "url": "https://github.com/directive-run/directive",
    "directory": "packages/ai"
  },
  "homepage": "https://directive.run",
  "bugs": {
    "url": "https://github.com/directive-run/directive/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "directive",
    "ai",
    "agents",
    "guardrails",
    "orchestration",
    "llm",
    "constraint-driven"
  ],
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "require": "./dist/testing.cjs",
      "import": "./dist/testing.js"
    },
    "./anthropic": {
      "types": "./dist/anthropic.d.ts",
      "require": "./dist/anthropic.cjs",
      "import": "./dist/anthropic.js"
    },
    "./openai": {
      "types": "./dist/openai.d.ts",
      "require": "./dist/openai.cjs",
      "import": "./dist/openai.js"
    },
    "./ollama": {
      "types": "./dist/ollama.d.ts",
      "require": "./dist/ollama.cjs",
      "import": "./dist/ollama.js"
    },
    "./gemini": {
      "types": "./dist/gemini.d.ts",
      "require": "./dist/gemini.cjs",
      "import": "./dist/gemini.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "cd ../.. && vitest run packages/ai/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@directive-run/core": "*"
  },
  "devDependencies": {
    "@directive-run/core": "workspace:*",
    "@types/node": "^25.2.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
