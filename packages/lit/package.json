{
  "name": "@directive-run/lit",
  "version": "0.3.0",
  "description": "Lit web components adapter for Directive.",
  "license": "MIT",
  "author": "Jason Comes",
  "repository": {
    "type": "git",
    "url": "https://github.com/directive-run/directive",
    "directory": "packages/lit"
  },
  "homepage": "https://directive.run",
  "bugs": {
    "url": "https://github.com/directive-run/directive/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "directive",
    "lit",
    "web-components",
    "state-management",
    "reactive",
    "constraint-driven"
  ],
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@directive-run/core": "*",
    "lit": ">=3"
  },
  "devDependencies": {
    "@directive-run/core": "workspace:*",
    "@types/node": "^25.2.0",
    "lit": "^3.1.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
