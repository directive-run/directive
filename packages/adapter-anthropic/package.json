{
  "name": "@directive-run/adapter-anthropic",
  "version": "0.1.0",
  "description": "Anthropic adapter for Directive AI. Provides runners for the Anthropic Messages API.",
  "license": "MIT",
  "author": "Jason Comes",
  "repository": {
    "type": "git",
    "url": "https://github.com/DirectiveRun/DirectiveJS",
    "directory": "packages/adapter-anthropic"
  },
  "homepage": "https://directive.run",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "directive",
    "anthropic",
    "claude",
    "adapter",
    "llm",
    "ai",
    "agents"
  ],
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@directive-run/ai": "workspace:*"
  },
  "devDependencies": {
    "@directive-run/ai": "workspace:*",
    "@types/node": "^25.2.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
