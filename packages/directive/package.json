{
  "name": "directive",
  "version": "0.1.0",
  "description": "Constraint-driven runtime for TypeScript. Declare requirements, let the runtime resolve them.",
  "license": "MIT",
  "author": "Jason Comes",
  "repository": {
    "type": "git",
    "url": "https://github.com/DirectiveRun/DirectiveJS"
  },
  "homepage": "https://directive.run",
  "keywords": [
    "state-management",
    "constraints",
    "reactive",
    "runtime",
    "typescript",
    "signals"
  ],
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "require": "./dist/react.cjs",
      "import": "./dist/react.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "require": "./dist/vue.cjs",
      "import": "./dist/vue.js"
    },
    "./svelte": {
      "types": "./dist/svelte.d.ts",
      "require": "./dist/svelte.cjs",
      "import": "./dist/svelte.js"
    },
    "./solid": {
      "types": "./dist/solid.d.ts",
      "require": "./dist/solid.cjs",
      "import": "./dist/solid.js"
    },
    "./lit": {
      "types": "./dist/lit.d.ts",
      "require": "./dist/lit.cjs",
      "import": "./dist/lit.js"
    },
    "./plugins": {
      "types": "./dist/plugins/index.d.ts",
      "require": "./dist/plugins/index.cjs",
      "import": "./dist/plugins/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "require": "./dist/testing.cjs",
      "import": "./dist/testing.js"
    },
    "./templates": {
      "types": "./dist/templates.d.ts",
      "require": "./dist/templates.cjs",
      "import": "./dist/templates.js"
    },
    "./zustand": {
      "types": "./dist/zustand.d.ts",
      "require": "./dist/zustand.cjs",
      "import": "./dist/zustand.js"
    },
    "./react-query": {
      "types": "./dist/react-query.d.ts",
      "require": "./dist/react-query.cjs",
      "import": "./dist/react-query.js"
    },
    "./xstate": {
      "types": "./dist/xstate.d.ts",
      "require": "./dist/xstate.cjs",
      "import": "./dist/xstate.js"
    },
    "./redux": {
      "types": "./dist/redux.d.ts",
      "require": "./dist/redux.cjs",
      "import": "./dist/redux.js"
    },
    "./openai-agents": {
      "types": "./dist/openai-agents.d.ts",
      "require": "./dist/openai-agents.cjs",
      "import": "./dist/openai-agents.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18",
    "vue": ">=3",
    "svelte": ">=4",
    "solid-js": ">=1",
    "lit": ">=3",
    "zod": ">=3",
    "zustand": ">=4",
    "@tanstack/react-query": ">=5",
    "xstate": ">=5",
    "@reduxjs/toolkit": ">=2",
    "@openai/agents": ">=0.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    },
    "lit": {
      "optional": true
    },
    "zod": {
      "optional": true
    },
    "zustand": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    },
    "xstate": {
      "optional": true
    },
    "@reduxjs/toolkit": {
      "optional": true
    },
    "@openai/agents": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "@types/react": "^18.3.3",
    "lit": "^3.1.0",
    "react": "^18.3.1",
    "solid-js": "^1.8.0",
    "svelte": "^4.2.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vue": "^3.4.0"
  }
}
