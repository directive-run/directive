{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@shared/*": ["./shared/*"],
      "@helpers/*": ["./helpers/*"]
    }
  },
  "include": ["specs/**/*.ts", "helpers/**/*.ts", "shared/**/*.ts"]
}
