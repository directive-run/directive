{
  "$schema": "https://unpkg.com/@changesets/config@3.1.1/schema.json",
  "changelog": ["@changesets/changelog-github", { "repo": "directive-run/directive" }],
  "commit": false,
  "fixed": [
    [
      "@directive-run/core",
      "@directive-run/react",
      "@directive-run/vue",
      "@directive-run/svelte",
      "@directive-run/solid",
      "@directive-run/lit"
    ],
    [
      "@directive-run/ai"
    ]
  ],
  "access": "public",
  "baseBranch": "main",
  "updateInternalDependencies": "patch",
  "ignore": [
    "directive-monorepo",
    "directive-website",
    "@directive-run/vite-plugin-api-proxy",
    "@directive-run/example-counter",
    "@directive-run/example-checkers",
    "@directive-run/example-contact-form",
    "@directive-run/example-eleven-up",
    "@directive-run/example-feature-flags",
    "@directive-run/example-multi-module",
    "@directive-run/example-newsletter",
    "@directive-run/example-schema-patterns"
  ]
}
